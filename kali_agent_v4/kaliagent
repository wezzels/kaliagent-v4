@c2.command()
def list():
    """List active C2 agents"""
    console.print("[bold green]📡 Active C2 Agents[/bold green]\n")
    
    agents = [
        ("agent-001", "10.0.100.10", "windows", "active"),
        ("agent-002", "10.0.100.20", "linux", "active"),
        ("agent-003", "10.0.100.30", "linux", "sleeping"),
    ]
    
    table = Table(show_header=True, header_style="bold cyan")
